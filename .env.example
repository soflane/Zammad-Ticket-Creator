# =============================================================================
# VITE_* prefix is required by Vite for dev mode (npm run dev).
# In Docker, docker-compose.yml maps these to server-side variables (no VITE_
# prefix) so they are never baked into the production JS bundle.
#
# To deploy: copy this file to .env and fill in real values.
# =============================================================================

# Zammad API token (sensitive — injected server-side by Nginx in Docker)
VITE_ZAMMAD_TOKEN=your_api_token_here

# Zammad instance base URL (used by Vite proxy in dev, and Nginx proxy_pass in Docker)
VITE_ZAMMAD_BASE_URL=https://your-zammad-instance.com

# Default Ticket Settings (served via /config.js at runtime in Docker, no rebuild needed)
VITE_DEFAULT_GROUP=Support            # Your default group name
VITE_DEFAULT_STATE_ID=2               # e.g., 2 for 'open'
VITE_DEFAULT_TAGS=internal,silent     # Comma-separated tags

# Internal Email (served via /config.js at runtime in Docker)
VITE_INTERNAL_EMAIL=internal@example.com  # Your internal email
